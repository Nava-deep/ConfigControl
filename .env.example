CONFIG_SERVICE_APP_NAME=Config Control Plane
CONFIG_SERVICE_ENVIRONMENT=development
CONFIG_SERVICE_LOG_LEVEL=INFO
CONFIG_SERVICE_HOST=0.0.0.0
CONFIG_SERVICE_PORT=8080
CONFIG_SERVICE_DATABASE_URL=postgresql+psycopg://config:config@localhost:5432/configdb
CONFIG_SERVICE_REDIS_URL=redis://localhost:6379/0
CONFIG_SERVICE_USE_REDIS=true
CONFIG_SERVICE_CANARY_POLL_INTERVAL_SECONDS=1.0
CONFIG_SERVICE_LONGPOLL_TIMEOUT_SECONDS=25
CONFIG_SERVICE_REQUEST_TIMEOUT_SECONDS=5.0
CONFIG_SERVICE_DEFAULT_TARGET=default
CONFIG_SERVICE_WEBSOCKET_RECONNECT_SECONDS=1.0
CONFIG_SERVICE_NOTIFICATION_CHANNEL=config-events
CONFIG_SERVICE_SDK_CACHE_DIR=.cache/config-sdk
CONFIG_SERVICE_TELEMETRY_HASH_SALT=replace-me-before-production
